#!/usr/bin/env bash
# livediag_bridge_stability.sh
# Single-Snapshot der Hybrid-Bridge (Octopus@can1, EBB36@can0) → TSV-Zeile.
# Aufruf alle 60s via systemd-User-Timer ODER tmux-while-Loop.
# NICHT als root laufen — als m3d.
#
# Output: ~/printer_data/logs/bridge_stability.log
# Header wird einmalig geschrieben, falls Datei fehlt/leer.

set -u
LOG="${HOME}/printer_data/logs/bridge_stability.log"
MOON="http://127.0.0.1:7125"

mkdir -p "$(dirname "$LOG")"

# Header (nur wenn Datei leer/neu)
if [[ ! -s "$LOG" ]]; then
  printf "ts\tcan0_state\tcan1_state\tcan0_rxerr\tcan0_txerr\tcan0_busoff\tcan1_rxerr\tcan1_txerr\tcan1_busoff\tklipper\tprinter_state\tmcus_ready\tmcus_total\twatchdog_lines\tthrottled\tdmesg_enobufs\tdmesg_eproto\tdmesg_echoid\n" >> "$LOG"
fi

ts="$(date -Iseconds)"

# CAN-State + Error-Counter
get_can_field() {
  local iface="$1" field="$2"
  ip -details -statistics link show "$iface" 2>/dev/null \
    | awk -v f="$field" '$0 ~ f {for (i=1;i<=NF;i++) if ($i==f) {print $(i+1); exit}}'
}
can0_state="$(ip -details link show can0 2>/dev/null | awk '/state/ {for(i=1;i<=NF;i++) if($i=="state"){print $(i+1); exit}}')"
can1_state="$(ip -details link show can1 2>/dev/null | awk '/state/ {for(i=1;i<=NF;i++) if($i=="state"){print $(i+1); exit}}')"
: "${can0_state:=NA}"; : "${can1_state:=NA}"

# berkeley packet stats für rx/tx/bus-off
parse_can_errors() {
  local iface="$1"
  ip -details -statistics link show "$iface" 2>/dev/null | awk '
    /bus-error|error-warning|error-passive|bus-off/ {next}
    /berr-counter/ {
      for(i=1;i<=NF;i++){
        if($i=="tx") txerr=$(i+1)
        if($i=="rx") rxerr=$(i+1)
      }
    }
    /restart-ms/ {restarts=1}
    END { printf "%s\t%s", (rxerr?rxerr:0), (txerr?txerr:0) }
  '
}
read can0_rx can0_tx <<< "$(parse_can_errors can0)"
read can1_rx can1_tx <<< "$(parse_can_errors can1)"
: "${can0_rx:=0}"; : "${can0_tx:=0}"; : "${can1_rx:=0}"; : "${can1_tx:=0}"

# bus-off-Counter (aus Statistics-Block, "bus-off")
can0_busoff="$(ip -details -statistics link show can0 2>/dev/null | awk '/bus-off/ {print $NF; exit}')"
can1_busoff="$(ip -details -statistics link show can1 2>/dev/null | awk '/bus-off/ {print $NF; exit}')"
: "${can0_busoff:=0}"; : "${can1_busoff:=0}"

# Klipper-Service
klipper="$(systemctl is-active klipper 2>/dev/null || echo unknown)"

# Moonraker /printer/info → state + Liste der MCUs
moon_json="$(curl -fsS --max-time 3 "${MOON}/printer/info" 2>/dev/null || echo '{}')"
printer_state="$(printf '%s' "$moon_json" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("result",{}).get("state","NA"))' 2>/dev/null || echo NA)"

# MCUs-ready aus /printer/objects/query?... ist genauer.
# Wir fragen einfach mcus über printer/objects/list und dann query
mcus_json="$(curl -fsS --max-time 3 "${MOON}/printer/objects/list" 2>/dev/null || echo '{}')"
mcu_names="$(printf '%s' "$mcus_json" | python3 -c '
import sys,json
try:
  d=json.load(sys.stdin)
  objs=d.get("result",{}).get("objects",[])
  print(" ".join([o for o in objs if o=="mcu" or o.startswith("mcu ")]))
except Exception:
  pass
' 2>/dev/null)"
mcus_total=0; mcus_ready=0
if [[ -n "${mcu_names// }" ]]; then
  q="$(printf '%s' "$mcu_names" | tr ' ' '\n' | awk 'NF{printf "%s%s=mcu_version", (NR>1?"&":""), $0}')"
  mcus_query="$(curl -fsS --max-time 3 "${MOON}/printer/objects/query?${q}" 2>/dev/null || echo '{}')"
  read mcus_total mcus_ready <<< "$(printf '%s' "$mcus_query" | python3 -c '
import sys,json
try:
  d=json.load(sys.stdin)
  st=d.get("result",{}).get("status",{})
  total=len(st); ready=sum(1 for v in st.values() if v.get("mcu_version"))
  print(total, ready)
except Exception:
  print(0,0)
' 2>/dev/null)"
fi
: "${mcus_total:=0}"; : "${mcus_ready:=0}"

# gs_usb-Watchdog-Logfile (Zeilenzahl, falls vorhanden)
WD_LOG="/var/log/gs-usb-watchdog.log"
if [[ -r "$WD_LOG" ]]; then
  watchdog_lines="$(wc -l < "$WD_LOG" 2>/dev/null || echo 0)"
else
  watchdog_lines=0
fi

# Throttling
throttled="$(vcgencmd get_throttled 2>/dev/null | awk -F= '{print $2}')"
: "${throttled:=NA}"

# dmesg-Counter seit letztem Boot (best effort, dmesg darf für m3d lesbar sein → meist sudo nötig)
# Falls kein Lese-Recht: 0,0,0
if dmesg -T &>/dev/null; then
  dmesg_enobufs="$(dmesg -T 2>/dev/null | grep -c 'ENOBUFS' || echo 0)"
  dmesg_eproto="$(dmesg -T 2>/dev/null | grep -c 'EPROTO' || echo 0)"
  dmesg_echoid="$(dmesg -T 2>/dev/null | grep -c 'echo id' || echo 0)"
else
  dmesg_enobufs=0; dmesg_eproto=0; dmesg_echoid=0
fi

printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
  "$ts" "$can0_state" "$can1_state" \
  "$can0_rx" "$can0_tx" "$can0_busoff" \
  "$can1_rx" "$can1_tx" "$can1_busoff" \
  "$klipper" "$printer_state" "$mcus_ready" "$mcus_total" \
  "$watchdog_lines" "$throttled" \
  "$dmesg_enobufs" "$dmesg_eproto" "$dmesg_echoid" \
  >> "$LOG"
