############################## Carriage & Print Head Switch Logic ###############################

[gcode_macro toolchanger_sensor_status]
gcode:
    {% set svv = printer.save_variables.variables %}
    {% set active_tools = svv.active_tools|default(5)|int %}
    {% set t0 = printer["gcode_button t0_dock_sensor"].state if active_tools > 0 else "N/A" %}
    {% set t1 = printer["gcode_button t1_dock_sensor"].state if active_tools > 1 else "N/A" %}
    {% set t2 = printer["gcode_button t2_dock_sensor"].state if active_tools > 2 else "N/A" %}
    {% set t3 = printer["gcode_button t3_dock_sensor"].state if active_tools > 3 else "N/A" %}
    {% set t4 = printer["gcode_button t4_dock_sensor"].state if active_tools > 4 else "N/A" %}
    { action_respond_info(
        "Carriage=" ~ printer["gcode_button carriage_tool_sensor"].state ~
        " | PH1=" ~ t0 ~
        " | PH2=" ~ t1 ~
        " | PH3=" ~ t2 ~
        " | PH4=" ~ t3 ~
        " | PH5=" ~ t4
    ) }

[gcode_macro _TOOLCHANGER_PAUSE]
gcode:
  {% set msg = params.MSG|default("toolchanger_error")|replace("_", " ") %}
  { action_respond_info(msg) }
  M117 {msg}
  {% if printer.print_stats.state == "printing" %}
    PAUSE_BASE
  {% endif %}

[gcode_macro _toolchanger_state]
variable_can_continue: 1
gcode:

[gcode_macro DOCK]
gcode:
  {% set svv = printer.save_variables.variables %}
  {% set active_tools = svv.active_tools|default(0)|int %}
  {% set carriage = printer["gcode_button carriage_tool_sensor"].state %}
  _TOOLCHANGER_CLEAR_PENDING
  SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=1
  {% if active_tools < 1 %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
    _TOOLCHANGER_PAUSE MSG=active_tools_is_invalid
  {% else %}
    {% set t0_docked = 1 if active_tools > 0 and printer["gcode_button t0_dock_sensor"].state == "PRESSED" else 0 %}
    {% set t1_docked = 1 if active_tools > 1 and printer["gcode_button t1_dock_sensor"].state == "PRESSED" else 0 %}
    {% set t2_docked = 1 if active_tools > 2 and printer["gcode_button t2_dock_sensor"].state == "PRESSED" else 0 %}
    {% set t3_docked = 1 if active_tools > 3 and printer["gcode_button t3_dock_sensor"].state == "PRESSED" else 0 %}
    {% set t4_docked = 1 if active_tools > 4 and printer["gcode_button t4_dock_sensor"].state == "PRESSED" else 0 %}
    {% set docked_count = t0_docked + t1_docked + t2_docked + t3_docked + t4_docked %}
    {% set t0_open = 1 if active_tools > 0 and printer["gcode_button t0_dock_sensor"].state == "RELEASED" else 0 %}
    {% set t1_open = 1 if active_tools > 1 and printer["gcode_button t1_dock_sensor"].state == "RELEASED" else 0 %}
    {% set t2_open = 1 if active_tools > 2 and printer["gcode_button t2_dock_sensor"].state == "RELEASED" else 0 %}
    {% set t3_open = 1 if active_tools > 3 and printer["gcode_button t3_dock_sensor"].state == "RELEASED" else 0 %}
    {% set t4_open = 1 if active_tools > 4 and printer["gcode_button t4_dock_sensor"].state == "RELEASED" else 0 %}
    {% set open_count = t0_open + t1_open + t2_open + t3_open + t4_open %}
    {% if carriage != "PRESSED" %}
      {% if docked_count == active_tools %}
        SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=1
        { action_respond_info("all installed print heads are already docked") }
      {% else %}
        SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
        _TOOLCHANGER_PAUSE MSG=carriage_empty_but_not_all_installed_print_heads_read_docked
      {% endif %}
    {% elif open_count == 0 %}
      SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
      _TOOLCHANGER_PAUSE MSG=carriage_triggered_but_all_installed_print_heads_read_docked
    {% elif open_count > 1 %}
      SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
      _TOOLCHANGER_PAUSE MSG=multiple_installed_print_heads_read_undocked_cannot_determine_which_head_to_dock
    {% else %}
      {% if t0_open %}
        {% if printer["gcode_button carriage_tool_sensor"].state != "PRESSED" %}
          SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
          _TOOLCHANGER_PAUSE MSG=carriage_lost_before_docking_PH1
        {% else %}
          _DOCK_PH1
          {% set tool = 0 %}
        {% endif %}
      {% elif t1_open %}
        {% if printer["gcode_button carriage_tool_sensor"].state != "PRESSED" %}
          SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
          _TOOLCHANGER_PAUSE MSG=carriage_lost_before_docking_PH2
        {% else %}
          _DOCK_PH2
          {% set tool = 1 %}
        {% endif %}
      {% elif t2_open %}
        {% if printer["gcode_button carriage_tool_sensor"].state != "PRESSED" %}
          SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
          _TOOLCHANGER_PAUSE MSG=carriage_lost_before_docking_PH3
        {% else %}
          _DOCK_PH3
          {% set tool = 2 %}
        {% endif %}
      {% elif t3_open %}
        {% if printer["gcode_button carriage_tool_sensor"].state != "PRESSED" %}
          SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
          _TOOLCHANGER_PAUSE MSG=carriage_lost_before_docking_PH4
        {% else %}
          _DOCK_PH4
          {% set tool = 3 %}
        {% endif %}
      {% else %}
        {% if printer["gcode_button carriage_tool_sensor"].state != "PRESSED" %}
          SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
          _TOOLCHANGER_PAUSE MSG=carriage_lost_before_docking_PH5
        {% else %}
          _DOCK_PH5
          {% set tool = 4 %}
        {% endif %}
      {% endif %}
      {% if printer["gcode_macro _toolchanger_state"].can_continue|int == 1 %}
        M400
        SET_GCODE_VARIABLE MACRO=_post_dock_state VARIABLE=tool VALUE={tool}
        UPDATE_DELAYED_GCODE ID=_delayed_post_dock_check DURATION=0.1
      {% endif %}
    {% endif %}
  {% endif %}

[gcode_macro _PRE_SELECT_CHECK]
gcode:
  {% set tool = params.TOOL|int %}
  {% set svv = printer.save_variables.variables %}
  {% set active_tools = svv.active_tools|default(0)|int %}
  {% set carriage_pressed = 1 if printer["gcode_button carriage_tool_sensor"].state == "PRESSED" else 0 %}
  _TOOLCHANGER_CLEAR_PENDING
  SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=1
  {% if tool < 0 or tool >= active_tools %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
    _TOOLCHANGER_PAUSE MSG={"PH" ~ (tool + 1) ~ "_is_not_installed"}
  {% else %}
    {% if carriage_pressed %}
      DOCK
    {% endif %}
    _PRE_SELECT_VERIFY TOOL={tool}
  {% endif %}

[gcode_macro _PRE_SELECT_VERIFY]
gcode:
  {% set tool = params.TOOL|int %}
  {% set name = "gcode_button t" ~ tool ~ "_dock_sensor" %}
  M400
  G4 P300
  {% if printer["gcode_macro _toolchanger_state"].can_continue|int == 0 %}
    { action_respond_info("pre-select check failed") }
  {% elif printer["gcode_button carriage_tool_sensor"].state == "PRESSED" %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
    _TOOLCHANGER_PAUSE MSG=carriage_still_occupied_after_docking
  {% elif printer[name].state != "PRESSED" %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
    _TOOLCHANGER_PAUSE MSG={"PH" ~ (tool + 1) ~ "_is_not_docked_cannot_select"}
  {% else %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=1
    { action_respond_info("pre-select check passed for PH" ~ (tool + 1)) }
  {% endif %}

[gcode_macro _post_select_state]
variable_tool: -1
gcode:

[gcode_macro _post_dock_state]
variable_tool: -1
gcode:

[gcode_macro _TOOLCHANGER_CLEAR_PENDING]
gcode:
  UPDATE_DELAYED_GCODE ID=_delayed_post_select_check DURATION=0
  UPDATE_DELAYED_GCODE ID=_delayed_post_dock_check DURATION=0
  SET_GCODE_VARIABLE MACRO=_post_select_state VARIABLE=tool VALUE=-1
  SET_GCODE_VARIABLE MACRO=_post_dock_state VARIABLE=tool VALUE=-1

[gcode_macro _POST_SELECT_CHECK]
gcode:
  {% set tool = params.TOOL|int %}
  M400
  SET_GCODE_VARIABLE MACRO=_post_select_state VARIABLE=tool VALUE={tool}
  UPDATE_DELAYED_GCODE ID=_delayed_post_select_check DURATION=0.1

[delayed_gcode _delayed_post_select_check]
gcode:
  {% set tool = printer["gcode_macro _post_select_state"].tool|int %}
  {% set name = "gcode_button t" ~ tool ~ "_dock_sensor" %}
  {% if tool < 0 %}
    { action_respond_info("post select check skipped, invalid tool") }
  {% elif printer["gcode_button carriage_tool_sensor"].state != "PRESSED" %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
    _TOOLCHANGER_PAUSE MSG={"pickup_failed_carriage_switch_not_triggered_for_PH" ~ (tool + 1)}
  {% elif printer[name].state != "RELEASED" %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
    _TOOLCHANGER_PAUSE MSG={"pickup_failed_PH" ~ (tool + 1) ~ "_still_reads_docked"}
  {% else %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=1
    { action_respond_info("PH" ~ (tool + 1) ~ " selected successfully") }
  {% endif %}
  SET_GCODE_VARIABLE MACRO=_post_select_state VARIABLE=tool VALUE=-1

[delayed_gcode _delayed_post_dock_check]
gcode:
  {% set tool = printer["gcode_macro _post_dock_state"].tool|int %}
  {% set name = "gcode_button t" ~ tool ~ "_dock_sensor" %}
  {% if tool < 0 %}
    { action_respond_info("post dock check skipped, invalid tool") }
  {% elif printer["gcode_button carriage_tool_sensor"].state != "RELEASED" %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
    _TOOLCHANGER_PAUSE MSG={"dock_failed_carriage_still_triggered_after_docking_PH" ~ (tool + 1)}
  {% elif printer[name].state != "PRESSED" %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=0
    _TOOLCHANGER_PAUSE MSG={"dock_failed_PH" ~ (tool + 1) ~ "_switch_not_triggered_after_docking"}
  {% else %}
    SET_GCODE_VARIABLE MACRO=_toolchanger_state VARIABLE=can_continue VALUE=1
    { action_respond_info("PH" ~ (tool + 1) ~ " docked successfully") }
  {% endif %}
  SET_GCODE_VARIABLE MACRO=_post_dock_state VARIABLE=tool VALUE=-1
